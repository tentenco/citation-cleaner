{
  "manifest_version": 3,
  "name": "Citation Cleaner",
  "version": "0.4.0",
  "description": "Strip citations, source trails, and tracking clutter from AI chatbot text — cleaned in a popup, entirely in your browser.",
  "action": {
    "default_title": "Citation Cleaner",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "permissions": ["contextMenus"],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Open Citation Cleaner"
    }
  }
}
