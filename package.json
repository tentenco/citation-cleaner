{
  "name": "citation-cleaner",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "build:extension": "node extension/scripts/make-icons.mjs && esbuild extension/src/background.ts --bundle --format=esm --target=es2022 --outdir=extension/dist",
    "typecheck:extension": "tsc -p extension/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "puppeteer-core": "^25.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
